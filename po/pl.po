#: src/stream.ts:262
msgid ""
"File uses a format that cannot be played. Additional media codecs may be "
"required."
msgstr ""
"Plik używa formatu, którego nie można odtwarzać. Mogą być wymagane dodatkowe "
"kodeki."

#: src/stream.ts:274
msgid ""
"An error happened while trying to get information about the file. Please try "
"again."
msgstr ""
"Wystąpił błąd podczas próby uzyskania informacji o pliku. Proszę spróbować "
"ponownie."

#: src/stream.ts:285
msgid "File uses an invalid URI"
msgstr "Plik używa nieprawidłowego adresu URI"

#: src/stream.ts:296
msgid "Reading the file’s information timed out. Please try again."
msgstr ""
"Przekroczono czas odczytywania informacji o pliku. Proszę spróbować ponownie."

#: src/stream.ts:404
msgid "Unknown File"
msgstr "Nieznany plik"

#: src/stream.ts:649
msgid "The selected file doesn’t contain any audio"
msgstr "Zaznaczony plik nie zawiera żadnego dźwięku"

