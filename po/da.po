#: src/stream.ts:262
msgid ""
"File uses a format that cannot be played. Additional media codecs may be "
"required."
msgstr ""
"Filen bruger et format, som ikke kan afspilles. Yderligere codecs er måske "
"påkrævet."

#: src/stream.ts:274
msgid ""
"An error happened while trying to get information about the file. Please try "
"again."
msgstr ""
"Der opstod en fejl under forsøget på at få oplysninger om filen. Prøv "
"venligst igen."

#: src/stream.ts:285
msgid "File uses an invalid URI"
msgstr "Filen bruger en ugyldig URI"

#: src/stream.ts:296
msgid "Reading the file’s information timed out. Please try again."
msgstr ""
"Læsning af filens information overskred tidsgrænsen. Prøv venligst igen."

#: src/stream.ts:404
msgid "Unknown File"
msgstr "Ukendt fil"

#: src/stream.ts:649
msgid "The selected file doesn’t contain any audio"
msgstr "Den valgte fil indeholder ingen lyd"

